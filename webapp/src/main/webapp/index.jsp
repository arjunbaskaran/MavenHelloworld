<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<!DOCTYPE html>
<html>
<head>
    <title>Illoominati Tees</title>
    <style>
        body {
            background-color: #000000;
            color: #00ff66;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        header {
            text-align: center;
            padding: 40px;
            border-bottom: 2px solid #00ff66;
        }

        h1, h2 {
